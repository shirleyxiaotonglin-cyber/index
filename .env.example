# PostgreSQL（本地开发）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskops?schema=public"
# 部署到 Neon / Supabase 等时通常需要 ssl，例如：
# DATABASE_URL="postgresql://user:pass@host.region.provider.com/db?sslmode=require"

# NextAuth — generate: openssl rand -base64 32（生产环境必须设置）
AUTH_SECRET="change-me-in-production-use-long-random-string"

# 演示账号（首次登录会自动写入数据库；设为 false 可关闭）
# ENABLE_DEMO_BOOTSTRAP="false"
# DEMO_EMAIL="435236356@qq.com"
# DEMO_PASSWORD="123456"
# 兼容旧变量名
# NEXTAUTH_SECRET="same-as-above"

# 站点根地址（本地 / 生产必须与实际访问 URL 一致）
AUTH_URL="http://localhost:3000"
# 部署到 Vercel 等时改为公网地址，例如：
# AUTH_URL="https://your-app.vercel.app"

# LLM（统一走 OpenRouter；密钥仅在服务端）
# OPENROUTER_API_KEY="sk-or-..."
# 会议纪要仅读 OPENROUTER_MEETING_MODEL（不读 OPENROUTER_MODEL，避免全局 70b 拖垮会议解析）
# 默认代码为 deepseek/deepseek-v3.2；
# 若要 70b 再显式写：OPENROUTER_MEETING_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# OPENROUTER_MEETING_MODEL="deepseek/deepseek-v3.2"
# 其它 AI（/api/ai）用 OPENROUTER_MODEL，例如：
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
